# SimulAgent Backend Configuration Template
# 复制此文件为 .env 并填写实际值

# 阿里云百炼 API (OpenAI-compatible)
# 从系统环境变量读取，设置方法：
#   Windows: setx BAILIAN_API_KEY "your_key"
#   Linux/macOS: export BAILIAN_API_KEY=your_key
# 也可直接在此填写（不要提交到 git）：BAILIAN_API_KEY=your_key_here
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BAILIAN_MODEL=qwen3-8b

# 服务器配置
HOST=127.0.0.1
PORT=8765

# 本地 ASR（FunASR）
ASR_MODEL=paraformer-zh-streaming
ASR_DEVICE=cpu

# 存储路径
DATABASE_URL=sqlite:///../data/simulagent.db
MILVUS_DATA_DIR=../data/vectors

# 日志级别
LOG_LEVEL=INFO
